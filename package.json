{
  "name": "shadow-client",
  "version": "1.0.0",
  "description": "ShadowClient - Minecraft Launcher met Modrinth integratie",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.shadowclient.launcher",
    "productName": "ShadowClient",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!.github"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "author": "ShadowClient"
}
