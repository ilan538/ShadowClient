#include <windows.h>
#include <cstdlib>

int WINAPI WinMain(HINSTANCE hInst, HINSTANCE hPrev, LPSTR lpCmdLine, int nShowCmd) {
    MessageBox(NULL, "ShadowClient Launcher start...", "ShadowClient", MB_OK | MB_ICONINFORMATION);

    // Start de officiële Minecraft Launcher
    system("\"C:\\Program Files\\Minecraft Launcher\\MinecraftLauncher.exe\"");

    return 0;
}
